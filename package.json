{
  "name": "klantenzoeker",
  "version": "0.1.0",
  "description": "Supersnelle lokale klantenzoeker (Electron + SQLite)",
  "author": "Klantenzoeker",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "icon": "electron scripts/gen-icon.cjs",
    "dist": "electron-vite build && electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "exceljs": "^4.4.0",
    "pdfjs-dist": "^4.10.38",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "ag-grid-community": "^32.3.3",
    "electron": "^33.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.11"
  }
}
